# 미추적 application-local.yml 로 복사해 사용 (Git 커밋 금지: 비밀번호·Neon 키 등).
# OM과 동일 DB를 쓰려면 아래처럼 직접 값을 넣거나, IDE Run 설정 / 셸에서 환경 변수를 준다.
#
# 권장: 환경 변수 (application-dev.yml 이 읽음)
#   export SPRING_DATASOURCE_URL='jdbc:postgresql://...?sslmode=require&options=-c%20TimeZone%3DAsia/Seoul'
#   export SPRING_DATASOURCE_USERNAME='...'
#   export SPRING_DATASOURCE_PASSWORD='...'
#   ./mvnw spring-boot:run
#
# 로컬 전용으로 YAML에 직접 두는 예시 (주석 해제 후 값만 채움):
# spring:
#   datasource:
#     url: jdbc:postgresql://localhost:5432/shopeasy4
#     username: your_user
#     password: your_password
#     driver-class-name: org.postgresql.Driver
#
# 채팅·저장소에 노출된 DB 비밀번호는 즉시 DB 측에서 키 회전(재발급)할 것.
